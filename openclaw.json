{
  "meta": {
    "lastTouchedVersion": "2026.4.9",
    "lastTouchedAt": "2026-06-06T04:27:46.540Z"
  },
  "update": {
    "checkOnStart": false
  },
  "gateway": {
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ],
      "dangerouslyDisableDeviceAuth": true
    },
    "mode": "local",
    "port": 18790,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "executablePath": "/usr/bin/chromium"
  },
  "secrets": {
    "providers": {
      "default": {
        "source": "env"
      }
    },
    "defaults": {
      "env": "default"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-chat",
        "fallbacks": []
      },
      "models": {
        "deepseek/deepseek-chat": {
          "alias": "DeepSeek"
        }
      },
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "off",
        "scope": "agent",
        "workspaceAccess": "rw"
      },
      "elevatedDefault": "full",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 1,
        "allowAgents": [
          "autoresearch",
          "paper-review",
          "idea-generate",
          "reviewer",
          "ingest",
          "curate",
          "extract",
          "critic",
          "design",
          "spec",
          "audit",
          "ideate",
          "judge"
        ]
      }
    },
    "list": [
      {
        "id": "main",
        "name": "颖姗",
        "default": true,
        "workspace": "~/.openclaw/workspace/main"
      },
      {
        "id": "ingest",
        "name": "Ingest",
        "workspace": "~/.openclaw/workspace/ingest"
      },
      {
        "id": "curate",
        "name": "Curate",
        "workspace": "~/.openclaw/workspace/curate"
      },
      {
        "id": "extract",
        "name": "Extract",
        "workspace": "~/.openclaw/workspace/extract"
      },
      {
        "id": "critic",
        "name": "Critic",
        "workspace": "~/.openclaw/workspace/critic"
      },
      {
        "id": "design",
        "name": "Design",
        "workspace": "~/.openclaw/workspace/design"
      },
      {
        "id": "spec",
        "name": "Spec",
        "workspace": "~/.openclaw/workspace/spec"
      },
      {
        "id": "audit",
        "name": "Audit",
        "workspace": "~/.openclaw/workspace/audit"
      },
      {
        "id": "ideate",
        "name": "Ideate",
        "workspace": "~/.openclaw/workspace/ideate"
      },
      {
        "id": "judge",
        "name": "Judge",
        "workspace": "~/.openclaw/workspace/judge"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "feishu",
        "accountId": "main"
      }
    },
    {
      "agentId": "main",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "off",
      "mode": "final",
      "provider": "edge",
      "providers": {
        "edge": {
          "voice": "zh-CN-XiaoxiaoNeural",
          "lang": "zh-CN",
          "outputFormat": "ogg-24khz-16bit-mono-opus",
          "pitch": "+0Hz",
          "rate": "+0%",
          "volume": "+0%",
          "timeoutMs": 30000
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "tools": {
    "profile": "full",
    "sessions": {
      "visibility": "all"
    },
    "fs": {
      "workspaceOnly": false
    }
  },
  "channels": {
    "feishu": {
      "enabled": false,
      "domain": "feishu",
      "connectionMode": "websocket",
      "defaultAccount": "main",
      "accounts": {},
      "requireMention": true
    },
    "discord": {
      "enabled": false,
      "groupPolicy": "open"
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      },
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "isolated",
          "vault": {
            "path": "/home/node/.openclaw/wiki/main",
            "renderMode": "obsidian"
          },
          "obsidian": {
            "enabled": true,
            "useOfficialCli": true,
            "vaultName": "OpenClaw Wiki",
            "openAfterWrites": false
          },
          "bridge": {
            "enabled": false,
            "readMemoryArtifacts": true,
            "indexDreamReports": true,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": true
          },
          "ingest": {
            "autoCompile": true,
            "maxConcurrentJobs": 1,
            "allowUrlIngest": true
          },
          "search": {
            "backend": "shared",
            "corpus": "wiki"
          },
          "context": {
            "includeCompiledDigestPrompt": false
          },
          "render": {
            "preserveHumanBlocks": true,
            "createBacklinks": true,
            "createDashboards": true
          }
        }
      },
      "deepseek": {
        "enabled": true
      }
    },
    "installs": {},
    "slots": {
      "contextEngine": "legacy"
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "sessions": {
        "enabled": true
      },
      "limits": {
        "timeoutMs": 8000,
        "maxResults": 16
      },
      "update": {
        "onBoot": true,
        "interval": "5m",
        "debounceMs": 15000
      },
      "command": "/usr/local/bin/qmd",
      "paths": [
        {
          "path": ".",
          "name": "workspace",
          "pattern": "**/*.md"
        }
      ]
    }
  },
  "session": {
    "dmScope": "per-peer"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/anthropic",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.27,
              "output": 1.1,
              "cacheRead": 0.07,
              "cacheWrite": 0.27
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ],
        "api": "anthropic-messages",
        "authHeader": true,
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "DEEPSEEK_API_KEY"
        }
      }
    }
  },
  "auth": {
    "profiles": {
      "deepseek:cn": {
        "provider": "deepseek",
        "mode": "api_key"
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-22T15:41:27.246Z",
    "lastRunVersion": "2026.4.9",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  }
}
